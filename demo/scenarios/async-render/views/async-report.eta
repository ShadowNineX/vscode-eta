<section>
  <h1><%= it.title %></h1>
  <p>Generated by <%= it.generatedBy %></p>

  <% const summary = await captureAsync(async () => { %>
    <p><%= await it.fetchSummary() %></p>
  <% }) %>

  <%~ summary %>

  <ol>
    <% for (const row of it.rows) { %>
      <%~ await includeAsync("./async-line", { row }) %>
    <% } %>
  </ol>
</section>
