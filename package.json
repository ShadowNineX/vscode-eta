{
  "name": "eta",
  "displayName": "Eta",
  "description": "Advanced syntax highlighting, intellisense, autocomplete, and diagnostics for Eta templating language",
  "version": "0.1.0",
  "publisher": "eta-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShadowNineX/vscode-eta.git"
  },
  "bugs": {
    "url": "https://github.com/ShadowNineX/vscode-eta/issues"
  },
  "homepage": "https://github.com/ShadowNineX/vscode-eta#readme",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "eta",
    "template",
    "templating",
    "language",
    "intellisense",
    "syntax"
  ],
  "activationEvents": [
    "onLanguage:eta"
  ],
  "main": "./out/extension.js",
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.120.0",
    "@vitest/ui": "^4.1.6",
    "eta": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./ --noEmit && tsup",
    "watch": "tsc -watch -p ./ --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "pretest": "bun run compile"
  },
  "contributes": {
    "languages": [
      {
        "id": "eta",
        "aliases": [
          "Eta",
          "eta"
        ],
        "extensions": [
          ".eta"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "eta",
        "scopeName": "source.eta",
        "path": "./syntaxes/eta.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "eta",
        "path": "./snippets/eta.json"
      }
    ],
    "configuration": {
      "title": "Eta",
      "properties": {
        "eta.tags.open": {
          "type": "string",
          "default": "<%",
          "description": "Eta opening delimiter."
        },
        "eta.tags.close": {
          "type": "string",
          "default": "%>",
          "description": "Eta closing delimiter."
        },
        "eta.parse.exec": {
          "type": "string",
          "default": "",
          "description": "Eta evaluation tag prefix."
        },
        "eta.parse.interpolate": {
          "type": "string",
          "default": "=",
          "description": "Eta escaped interpolation tag prefix."
        },
        "eta.parse.raw": {
          "type": "string",
          "default": "~",
          "description": "Eta raw interpolation tag prefix."
        },
        "eta.customTags": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Custom Eta tag prefixes. Eta runtime customTags are handler functions; list only their prefixes here for language support."
        },
        "eta.varName": {
          "type": "string",
          "default": "it",
          "description": "Name of the Eta template data variable."
        },
        "eta.useWith": {
          "type": "boolean",
          "default": false,
          "description": "Expose top-level properties from the inferred data object as template variables."
        },
        "eta.functionHeader": {
          "type": "string",
          "default": "",
          "description": "JavaScript/TypeScript declarations to inject before template code for language features."
        },
        "eta.outputFunctionName": {
          "type": "string",
          "default": "output",
          "description": "Name of the Eta output helper function."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
